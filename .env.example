# Resend API key for the contact form (https://resend.com)
RESEND_API_KEY=

# Inbox that receives contact form submissions
CONTACT_EMAIL_TO=factumutah@gmail.com

# Verified sender address in Resend (e.g. "Factum <hello@factumfitness.com>")
# Until a custom domain is verified, use Resend's onboarding sender:
# CONTACT_EMAIL_FROM="Factum <onboarding@resend.dev>"
CONTACT_EMAIL_FROM=

# Public site URL used for absolute metadata, OG, sitemap, robots
NEXT_PUBLIC_SITE_URL=https://factumfitness.com
